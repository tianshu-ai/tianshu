# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
.next/
.turbo/
*.tsbuildinfo
# Tooling output dirs (top-level + workspace roots only). We don't
# blanket-ignore `build/` because plugins (e.g. microsandbox) keep
# real source under <plugin>/src/build/. Restrict ignores to where a
# build tool typically dumps artefacts.
/build/
packages/*/build/
plugins/*/build/

# Local env / secrets
.env
.env.local
.env.*.local
.env.bak
.env.bak-*
.env.backup*
packages/*/.env
packages/*/.env.local

# Local data / SQLite
data/
*.db
*.db-journal
*.db-shm
*.db-wal

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Testing / coverage
coverage/
.nyc_output/

# Local model / runtime config (contains API keys / SAP proxy URLs).
# Repo only ships *.example files; the real configs live under
# ~/.tianshu/ and must never be committed.
tianshu.models.json
.tianshu/
tianshu-home/
smoke-home/
local-config/

# Playwright
.playwright-mcp/
playwright-report/
test-results/

# Misc
*.pid
*.seed
*.pid.lock

# Synced from plugins/<id>/... by scripts/sync-builtin-plugins.mjs.
# Source of truth lives at plugins/<id>/.
packages/server/builtinConfig/plugins/*/manifest.json
packages/server/builtinConfig/plugins/*/skills/
packages/server/builtinConfig/plugins/*/templates/
packages/server/builtinConfig/plugins/*/locales/
packages/server/builtinConfig/plugins/*/agent-seeds/

# Local debugging / spike scripts — not tracked
probe-*.mjs
spike-*.mjs
test-*.mjs
/scripts/diagnose-*.mjs
