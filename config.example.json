// Tianshu global config — example.
//
// Copy this file to ~/.tianshu/config.json (or wherever TIANSHU_HOME points)
// and remove these comments + edit values for your setup.
// JSON5 not supported by the loader; strip the // comments before saving.
//
// Tenant configs at ~/.tianshu/tenants/<id>/config.json may override
// the same fields (with whitelist). Server-process knobs (server.*,
// logging.*, autoCreateDefault, builtinConfigDir) are GLOBAL ONLY.
{
  // Bootstrap a `default` tenant + `dev` user on first boot.
  // Set false in production / JWT-mode deployments.
  "autoCreateDefault": true,

  "server": {
    "port": 3110,
    "corsOrigin": "http://localhost:5183"
  },

  "logging": { "level": "info" },

  // Pick one model id from the providers catalog below.
  "defaultModel": "anthropic/claude-sonnet-4-6",

  // Provider catalog. Same shape as the closed-source `tianshu.models.json`.
  // apiKey strings accept ${VAR} and ${VAR:-fallback} placeholders.
  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "api": "anthropic-messages",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "group": "Cloud",
        "models": [
          { "id": "claude-sonnet-4-6", "name": "Claude Sonnet 4.6", "contextWindow": 1048576, "maxTokens": 65536 },
          { "id": "claude-opus-4-7",   "name": "Claude Opus 4.7",   "reasoning": true, "contextWindow": 1048576, "maxTokens": 65536 }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "api": "openai-completions",
        "apiKey": "${OPENAI_API_KEY}",
        "group": "Cloud",
        "models": [
          { "id": "gpt-4o", "name": "GPT-4o", "contextWindow": 128000, "maxTokens": 65536 }
        ]
      },
      "local-llama": {
        "baseUrl": "http://localhost:8083/v1",
        "api": "openai-completions",
        "group": "Local",
        "apiKey": "sk-no-key",
        "models": [
          { "id": "Qwen3.6-35B-A3B-Q8_0.gguf", "name": "Qwen3.6 35B (Local)", "contextWindow": 262144, "maxTokens": 8192 }
        ]
      }
    },

    // Cross-provider retry policy for transient LLM call failures
    // (network blips, 429 rate-limits, 5xx gateway errors, expired
    // JWT / 401). Applied at the single stream chokepoint, so it covers
    // the chat handler, worker agent-loop, and compaction uniformly.
    // Retries only happen BEFORE any content has streamed to the user
    // (never duplicates output); once tokens start flowing, a failure
    // surfaces as-is. All fields optional; defaults shown below.
    "resilience": {
      "enabled": true,
      "maxAttempts": 4,
      "baseDelayMs": 500,
      "maxDelayMs": 20000,
      "jitter": 0.25,
      "respectRetryAfter": true,
      "maxRetryAfterMs": 60000,
      "rateLimitFloorMs": 5000,
      "retryAfterContent": true
    }
  },

  "worker": {
    "count": 1,
    "pollMs": 10000,
    "model": "anthropic/claude-sonnet-4-6"
  },

  "branding": { "name": "Tianshu", "emoji": "⭐" },

  // User authentication. GLOBAL-ONLY. Absent / enabled:false (default)
  // keeps open dev mode (no login wall). Turn on + configure providers
  // via Settings → Admin, or hand-edit here.
  //
  // OAuth is fully config-driven — NO provider is hardcoded. Declare any
  // OAuth2/OIDC provider by (a) an OIDC `issuer` (discovery) or
  // (b) explicit authorizeUrl/tokenUrl/userInfoUrl. Admins live HERE
  // (auth.admins by email), not in a DB.
  "auth": {
    "enabled": false,
    "sessionSecret": "***}",
    // OAuth super-admins by email (global admin, all tenants).
    "admins": ["you@example.com"],
    // Local super-admin accounts (username+password). These are the
    // bootstrap / global admins — hashed into auth.db on boot. password
    // supports ${VAR} so no plaintext need live in the file.
    "superAdmins": [
      { "username": "admin", "password": "***}" }
    ],
    // Allow local users to self-register on the login page. Default
    // false — only super-admins + admin-created users exist.
    "allowRegistration": false,
    "tenantStrategy": "single",
    "singleTenant": "default",
    // OAuth/OIDC providers (optional — local password login always works
    // when auth is on). Fully config-driven; nothing hardcoded.
    "providers": [
      {
        "id": "my-sso",
        "displayName": "Company SSO",
        "clientId": "${OIDC_CLIENT_ID}",
        "clientSecret": "***}",
        "scopes": ["openid", "email", "profile"],
        "issuer": "https://sso.example.com/realms/main"
        // OR explicit endpoints instead of issuer (e.g. GitHub):
        // "authorizeUrl": "https://github.com/login/oauth/authorize",
        // "tokenUrl":     "https://github.com/login/oauth/access_token",
        // "userInfoUrl":  "https://api.github.com/user",
        // "claims": { "subject": "id", "email": "email", "name": "name" }
      }
    ]
  }
}
