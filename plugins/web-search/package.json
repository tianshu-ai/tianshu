{
  "name": "@tianshu-builtin/plugin-web-search",
  "version": "0.1.0",
  "private": true,
  "description": "Web search tool for tianshu agents (Tavily / Brave Search providers).",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": ["dist", "src", "skills", "manifest.json"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tianshu-ai/plugin-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
