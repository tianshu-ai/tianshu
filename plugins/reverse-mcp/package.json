{
  "name": "@tianshu-builtin/plugin-reverse-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Reverse-MCP bridge: local software (browser, files, shell) dials into tianshu over the chat WebSocket and registers as an MCP server the agent can call.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": [
    "dist",
    "src",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tianshu-ai/plugin-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
