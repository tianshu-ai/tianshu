{
  "name": "@tianshu-builtin/plugin-workboard",
  "version": "0.1.0",
  "private": true,
  "description": "Kanban task board + worker pool for Tianshu (builtin plugin, ADR-0002).",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": ["dist", "src", "skills", "manifest.json"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tianshu/plugin-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
