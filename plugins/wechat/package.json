{
  "name": "@tianshu-builtin/plugin-wechat",
  "version": "0.1.0",
  "private": true,
  "description": "WeChat (Weixin) channel for tianshu via Tencent's iLink bot API. Scan QR to log in; messages route through the channel system.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": [
    "dist",
    "src",
    "skills",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tianshu-ai/plugin-sdk": "*",
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.6",
    "react": "^19.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
