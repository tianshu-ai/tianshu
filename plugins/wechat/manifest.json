{
  "id": "wechat",
  "version": "0.1.0",
  "displayName": "WeChat (微信)",
  "description": "WeChat channel backed by Tencent's iLink bot API. Scan a QR code with the WeChat app to authorise; inbound DMs from authorised users route to the agent through the channel system.",
  "author": "tianshu-ai",
  "license": "MIT",
  "permissions": ["network.external"],
  "server": { "entry": "@tianshu-builtin/plugin-wechat/server" },
  "client": { "entry": "@tianshu-builtin/plugin-wechat/client" },
  "contributes": {
    "channels": [
      {
        "id": "wechat",
        "displayName": "WeChat",
        "module": "WeChatChannel",
        "since": "0.3.36"
      }
    ],
    "adminPages": [
      {
        "id": "main",
        "displayName": "WeChat",
        "icon": "MessageSquare",
        "component": "WeChatAdminPage",
        "group": "Channels",
        "order": 100
      }
    ],
    "apiRoutes": [
      { "method": "POST", "path": "/login/start", "handler": "loginStart" },
      { "method": "POST", "path": "/login/poll", "handler": "loginPoll" },
      { "method": "GET", "path": "/bindings", "handler": "listBindings" },
      { "method": "DELETE", "path": "/bindings/:id", "handler": "deleteBinding" }
    ]
  }
}
