{
  "name": "@tianshu-builtin/plugin-openshell",
  "version": "0.1.0",
  "description": "Tianshu plugin: shell sandbox backed by NVIDIA OpenShell.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": [
    "dist",
    "src",
    "skills",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tianshu-ai/plugin-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
