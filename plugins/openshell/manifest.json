{
  "id": "openshell",
  "displayName": "OpenShell (Docker)",
  "version": "0.1.0",
  "description": "Run shell commands in OpenShell-managed Docker sandboxes (NVIDIA OpenShell). Alternative to microsandbox: avoids macOS Hypervisor.framework (no idle-CPU burn on Apple Silicon Tahoe), includes network/inference policy support. MVP provides sandbox.shell only; browser sidecar and per-task pool are tracked for follow-ups.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/NVIDIA/OpenShell",
  "provides": ["sandbox.shell"],
  "requires": [],
  "contributes": {
    "sandboxes": [
      {
        "id": "main",
        "kind": "shell",
        "displayName": "OpenShell",
        "module": "OpenShellRunner"
      }
    ],
    "tools": [
      {
        "id": "exec",
        "module": "ExecTool",
        "since": "0.4.0"
      },
      {
        "id": "reset_sandbox",
        "module": "ResetSandboxTool",
        "since": "0.4.0"
      },
      {
        "id": "get_sandbox_status",
        "module": "GetSandboxStatusTool",
        "since": "0.4.0"
      }
    ],
    "skills": [
      {
        "id": "exec-howto",
        "path": "skills/openshell-exec-howto.md"
      }
    ]
  }
}
