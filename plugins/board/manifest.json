{
  "id": "board",
  "version": "0.1.0",
  "displayName": "Boards",
  "description": "Render a user's HTML dashboards as interactive UI. Drop an index.html into board/<name>/ under your workspace and the agent can show it in chat via the `show_board` tool (as an MCP-UI resource) or you can browse boards in the side panel.",
  "author": "tianshu-ai",
  "license": "Apache-2.0",
  "permissions": ["workspace.read"],
  "client": { "entry": "@tianshu-builtin/plugin-board/client" },
  "server": { "entry": "@tianshu-builtin/plugin-board/server" },
  "contributes": {
    "topBarButtons": [
      {
        "id": "toggle",
        "icon": "Globe",
        "tooltip": "Boards",
        "opensPanel": "board.main",
        "order": 400
      }
    ],
    "rightPanels": [
      {
        "id": "main",
        "displayName": "Boards",
        "component": "BoardPanel"
      }
    ],
    "tools": [
      { "id": "show_board", "module": "ShowBoardTool", "since": "0.1.0" },
      { "id": "board_act",  "module": "BoardActTool",  "since": "0.2.0" }
    ],
    "wsMessages": [
      { "type": "board_act_response", "handler": "boardActResponse" }
    ],
    "apiRoutes": [
      { "method": "GET", "path": "/boards",              "handler": "listBoards"  },
      { "method": "GET", "path": "/boards/:name/index.html", "handler": "serveBoard" }
    ]
  }
}
