{
  "name": "@tianshu-builtin/plugin-board",
  "version": "0.1.0",
  "private": true,
  "description": "Boards: render a user's HTML dashboards (users/<id>/board/<name>/index.html) as MCP-UI resources in chat + a side panel. Builtin plugin (ADR-0002).",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": [
    "dist",
    "src",
    "manifest.json"
  ],
  "scripts": {
    "build": "node ../../scripts/build-plugin.mjs",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tianshu-ai/plugin-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
