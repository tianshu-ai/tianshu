# Tianshu — example environment file.
# Copy to .env and fill in values for local development.

# --- Server ---
# Default ports differ from the closed-source repo (3100/5173) so the two
# projects can run side-by-side. Set PORT=3100 / CORS_ORIGIN=http://localhost:5173
# if you specifically want the legacy ports.
PORT=3110
CORS_ORIGIN=http://localhost:5183

# --- Logging ---
LOG_LEVEL=info

# --- LLM provider credentials ---
# Add provider credentials here as needed once the agent runtime lands.
# See packages/server/src/index.ts for the env names actually consumed.

# --- Defaults ---
# DEFAULT_MODEL=
